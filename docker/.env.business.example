# ----------------------------
# Image overrides
# ----------------------------
CONTROL_PLANE_IMAGE=codex-pool-rust:local
DATA_PLANE_IMAGE=codex-pool-rust:local
USAGE_WORKER_IMAGE=codex-pool-rust:local
FRONTEND_IMAGE=codex-pool-frontend:local

# ----------------------------
# Published ports
# ----------------------------
CONTROL_PLANE_PORT=8090
DATA_PLANE_PORT=8091
FRONTEND_PORT=5173
PGBOUNCER_PORT=6432

# ----------------------------
# PostgreSQL / PgBouncer
# ----------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-postgres-password
POSTGRES_DB=codex_pool
PGBOUNCER_POOL_MODE=transaction
PGBOUNCER_AUTH_TYPE=scram-sha-256
PGBOUNCER_MAX_CLIENT_CONN=500
PGBOUNCER_DEFAULT_POOL_SIZE=50
PGBOUNCER_RESERVE_POOL_SIZE=20

# ----------------------------
# Redis / streams
# ----------------------------
REQUEST_LOG_STREAM=stream.request_log

# ----------------------------
# ClickHouse
# ----------------------------
CLICKHOUSE_DATABASE=default
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_ACCOUNT_TABLE=usage_account_hourly
CLICKHOUSE_TENANT_APIKEY_TABLE=usage_tenant_api_key_hourly
CLICKHOUSE_TENANT_ACCOUNT_TABLE=usage_tenant_account_hourly
CLICKHOUSE_REQUEST_LOG_TABLE=request_log_events

# ----------------------------
# Core secrets
# ----------------------------
CONTROL_PLANE_INTERNAL_AUTH_TOKEN=change-me-internal-token
CONTROL_PLANE_API_KEY_HMAC_KEYS=k1:replace-with-base64-32-byte-secret
CREDENTIALS_ENCRYPTION_KEY=replace-with-base64-32-byte-secret
ADMIN_PASSWORD=change-me-admin-password
ADMIN_JWT_SECRET=change-me-admin-jwt-secret

# ----------------------------
# Optional runtime tuning
# ----------------------------
ADMIN_USERNAME=admin
ADMIN_JWT_TTL_SEC=28800
RUST_LOG=info
SNAPSHOT_POLL_INTERVAL_MS=1000
ROUTING_STRATEGY=round_robin
ENABLE_INTERNAL_DEBUG_ROUTES=false
USAGE_WORKER_MODE=daemon
REQUEST_LOG_CONSUMER_GROUP=usage-worker
REQUEST_LOG_CONSUMER_NAME=usage-worker-1
